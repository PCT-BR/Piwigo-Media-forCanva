{
  "name": "piwigo-media-for-canva",
  "description": "Canva app for connecting to a Piwigo photo library through the Piwigo Canva Connector.",
  "engines": {
    "node": "^22 || ^24"
  },
  "scripts": {
    "start": "tsx ./scripts/start/start.ts",
    "start:preview": "npm run start -- --preview",
    "extract": "formatjs extract \"src/**/*.{ts,tsx}\" --out-file dist/messages_en.json",
    "build": "webpack --config webpack.config.ts --mode production && npm run extract",
    "lint:types": "tsc",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier '{src,styles,docs,scripts}/**/*.{css,html,md,ts,tsx,json,js,mjs}' --write",
    "format:check": "prettier '{src,styles,docs,scripts}/**/*.{css,html,md,ts,tsx,json,js,mjs}' --check",
    "format:file": "prettier $1 --no-config --write",
    "postinstall": "tsx ./scripts/copy_env.ts"
  },
  "keywords": [
    "canva",
    "piwigo",
    "media"
  ],
  "author": "PCT-BR",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": true,
  "dependencies": {
    "@canva/app-hooks": "^0.0.0-beta.4",
    "@canva/app-i18n-kit": "^1.2.0",
    "@canva/app-middleware": "^0.0.0-beta.5",
    "@canva/app-ui-kit": "^5.10.0",
    "@canva/asset": "^2.3.0",
    "@canva/design": "^2.9.0",
    "@canva/error": "^2.2.1",
    "@canva/intents": "^2.5.0",
    "@canva/platform": "^2.2.2",
    "@canva/user": "^2.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-intl": "^7.1.11"
  },
  "devDependencies": {
    "@canva/app-eslint-plugin": "^1.0.0-beta.7",
    "@canva/cli": "^2.0.0",
    "@formatjs/cli": "6.7.2",
    "@formatjs/ts-transformer": "3.14.0",
    "@svgr/webpack": "8.1.0",
    "@types/node": "22.19.17",
    "@types/node-forge": "1.3.14",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.1",
    "@types/webpack-env": "1.18.8",
    "chalk": "4.1.2",
    "cli-table3": "0.6.5",
    "css-loader": "7.1.2",
    "css-modules-typescript-loader": "4.0.1",
    "cssnano": "7.1.1",
    "dotenv": "16.6.0",
    "eslint": "9.34.0",
    "globals": "16.3.0",
    "mini-css-extract-plugin": "2.9.4",
    "node-forge": "1.4.0",
    "open": "8.4.2",
    "postcss-loader": "8.1.1",
    "prettier": "3.6.2",
    "style-loader": "4.0.0",
    "terser-webpack-plugin": "5.4.0",
    "ts-loader": "9.5.4",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "url-loader": "4.1.1",
    "webpack": "5.105.2",
    "webpack-cli": "6.0.1",
    "webpack-dev-server": "5.2.2",
    "yargs": "17.7.2"
  },
  "overrides": {
    "react-infinite-scroller": {
      "react": "$react"
    }
  }
}
